{
  "manifest_version": 3,
  "name": "代購+1 統計工具",
  "version": "1.0",
  "description": "自動抓取 Facebook 貼文留言中的 +1 資料",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.facebook.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}